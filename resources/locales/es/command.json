            "description": "Invita al bot al servidor mediante la URL de la aplicación. \n(LIMITADO A 90)",
            "embed": {
                "description": "%{prefix}\n\n\nPuedes agregarme a tu servidor usando [este enlace.](%{invite_url})",
                "footer": "Nota: Requiere permisos avanzados para una funcionalidad completa y la invitación está limitada a 90 servidores debido a la limitación de la discordia.",
                "status": {
                    "one": "Capacidad: **%{formatted}** servidor",
                    "other": "Capacidad: **%{formatted}** servidores"
                },
                "title": "Invitar a TongueBot"
            },
            "error": {
                "hardlimited": "No puedes invitar a TongueBot en este momento, ya que el recuento alcanzó el límite."
            },
            "name": "invite"
        },
        "name": "info",
        "os_info": {
            "description": "Muestra información del sistema operativo.",
            "embed": {
                "title": "Información del sistema operativo"
            },
            "name": "os_info"
        },
        "ping": {
            "description": "Pong!",
            "embed": {
                "title": "Pong! \n(%{latency} ms)"
            },
            "name": "ping"
        },
        "retrieve": {
            "description": "Recupera información del bot.",
