            },
            "error": {
                "forbidden": "No tengo el permiso **Administrar canales** para hacer eso."
            },
            "name": "retrieve"
        },
        "sync": {
            "description": "Sincroniza comandos",
            "name": "sync"
        },
        "timedate": {
            "description": "Muestra la hora en la zona horaria especificada",
            "embed": {
                "description": "En %{timezone_name}, es **%{timedate}**."
            },
            "name": "timedate"
        }
