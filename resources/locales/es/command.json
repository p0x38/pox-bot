    "contributors": {
        "description": "Un grupo para contribuyentes.",
        "list": {
            "description": "Enumera todos los contribuyentes.",
            "embeds": {
                "default": {
                    "description": "¡Aquí hay una lista de contribuyentes que ayudaron a mi bot! :3",
                    "title": "Colaboradores"
                }
            },
            "name": "list"
        },
        "name": "contributors",
