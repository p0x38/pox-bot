            "embeds": {
                "default": {
                    "title": "Información de %{name}"
                }
            },
            "name": "info"
        },
        "name": "channel",
        "slowmode": {
            "description": "Establece el retraso del modo lento",
            "embeds": {
                "successful": {
                    "description": "Se configuró correctamente el modo lento en **%{seconds}** para %{mention}.",
                    "title": "Modo lento actualizado"
                }
            },
            "name": "slowmode"
        }
