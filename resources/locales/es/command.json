            "description": "Establece el nick del usuario.",
            "embeds": {
                "changed": {
                    "description": "%{author} cambió el apodo de %{user}a **%{new_nickname}**."
                },
                "reset": {
                    "description": "%{author} cambió el apodo de %{user}."
                }
            },
            "reasons": {
                "changed": "Nombre cambiado por %{user} vía /user nick",
                "reset": "Apodo restablecido por %{user} a través de /user nick"
            }
        },
