    "economy": {
        "balance": {
            "description": "Compruebe su saldo actual.",
            "embeds": {
                "default": {
                    "footer": "Total de activos: %{coins} monedas",
                    "title": "Saldo de %{user}:3"
                }
            },
            "fields": {
                "bank": "Banco",
                "wallet": "Carteras"
            }
        },
        "buy": {
            "description": "Compra en el artículo de la tienda.",
            "embeds": {
                "item_unavailable": {
                    "description": "¡Ese artículo no está disponible para la venta! 3:<",
                    "title": "El artículo no está disponible"
                },
                "not_afford": {
                    "description": "¡No tienes suficientes monedas en tu monedero para comprar eso! 3:<",
                    "title": "No hay suficientes monedas"
                },
                "purchased": {
                    "description": "¡Comprado con éxito **%{item_name}**! Revisa tu inventario~ ;3",
                    "title": "Compra completada"
                }
            }
        },
        "daily": {
            "description": "Reclama tu recompensa diaria.",
            "embeds": {
                "default": {
                    "description": "¡Obtuviste monedas %{amount} por recompensas diarias! :3",
                    "title": "¡Has reclamado una recompensa diaria!"
                }
            }
        },
        "deposit": {
            "description": "Mover dinero de la cartera al banco.",
            "embeds": {
                "default": {
                    "description": "Monedas %{amount} depositadas con éxito. :3",
                    "title": "Depósito exitoso"
                }
            }
        },
        "description": "Un grupo para el sistema Economy.",
        "history": {
            "description": "Ver tus transacciones recientes."
        },
        "inventory": {
            "description": "Ver tus objetos.",
            "embeds": {
                "default": {
                    "title": "Inventario de %{user}"
                },
                "empty": {
                    "description": "Tu mochila está vacía. Compra algo para cambiar este texto y adivina. :3",
                    "title": "Mochila vacía"
                }
            }
        },
        "list": {
            "description": "Ver la tienda de artículos.",
            "fields": {
                "buy_price": "Precio: %{price} monedas",
                "not_sale": "No está en venta"
            }
        },
        "sell": {
            "description": "Vender sobre el objeto de vuelta a la tienda.",
            "embeds": {
                "sold": {
                    "description": "Vendido **%{item_name}",
                    "title": "Venta completada"
                },
                "unable_to_sell": {
                    "description": "¡La tienda no volverá a comprar! 3:<",
                    "title": "No se puede vender"
                }
            }
        },
        "withdraw": {
            "description": "Mueve dinero del banco al monedero.",
            "embeds": {
                "default": {
                    "description": "Monedas %{amount} retiradas con éxito. :3",
                    "title": "Retiro exitoso"
                }
            }
        },
        "work": {
            "description": "Gana algunas monedas por trabajar.",
            "embeds": {
                "default": {
                    "description": "¡Tienes monedas %{amount} funcionando! :3",
                    "title": "¡Ha trabajado por dinero!"
                },
                "tired": {
                    "description": "Necesitas descansar %{rem} minutos más. 3:",
                    "title": "¡No puedes trabajar ahora mismo!"
                }
            }
        }
    },
    "info": {
        "commit_data": {
            "description": "Muestra la última confirmación de git del bot.",
            "name": "commit_data"
        },
        "description": "Un grupo para informarse.",
