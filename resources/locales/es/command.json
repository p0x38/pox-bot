    "welcome": {
        "description": "Un grupo para Welcome. Cog",
        "embeds": {
            "join": {
                "description": "¡Bienvenido, %{mention}! Por favor, revisa las reglas en %{rules_mention}.",
                "description_no_rules": "¡Bienvenido al servidor, %{mention}!",
                "footer": "Ahora tenemos miembros %{count}.",
                "title": "¡Bienvenido a %{guild}!"
            },
            "left": {
                "description": "¡Audido, %{display}!",
                "title": "¡El miembro %{display} ha salido de %{guild}!"
            }
        },
        "set_channel": {
            "description": "Establecer el canal para enviar mensaje de Unión/Salida.",
            "embeds": {
                "disabled": {
                    "description": "La función de notificación de bienvenida ha sido desactivada."
                },
                "enabled": {
                    "description": "Se ha activado la función de notificación de bienvenida.\n El mensaje de bienvenida aparecerá en %{target_mention}."
                }
            }
        },
        "set_rules_channel": {
            "description": "Establece el canal de reglas para añadir un enlace.",
            "embeds": {
                "disabled": {
                    "description": "Se ha eliminado el canal de reglas para el mensaje de bienvenida."
                },
                "success": {
                    "description": "El canal de reglas para el mensaje de bienvenida se ha establecido en %{target_mention}."
                }
            }
        },
        "test": {
            "description": "Ejecutar una prueba para el canal de bienvenida",
            "embeds": {
                "sent": {
                    "description": "¡Prueba enviada con éxito al canal de bienvenida!"
                },
                "unconfigured": {
                    "description": "El canal de bienvenida no ha configurado en este gremio."
                }
            }
        }
