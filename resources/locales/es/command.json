    "user": {
        "avatar": {
            "description": "Muestra el avatar del usuario de Discord.",
            "embeds": {
                "default": {
                    "footer": "Solicitado por %{author}, el resultado se almacena en caché por un minuto.",
                    "title": "Avatar del usuario %{user}"
                }
            }
        },
        "description": "Un grupo para usuarios.",
